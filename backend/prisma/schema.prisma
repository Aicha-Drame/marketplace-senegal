generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


enum Role {
  ACHETEUR
  VENDEUR
  ADMIN
}

enum CommandeStatus {
  EN_ATTENTE
  PAYEE
  EXPEDIEE
  LIVREE
  ANNULEE
}

model Utilisateur {
  id         Int       @id @default(autoincrement())
  nom        String
  email      String    @unique
  motdepasse String
  role       Role      @default(ACHETEUR)

  // relations
  boutique   Boutique?
  commandes  Commande[]

  createdAt  DateTime  @default(now())
}

model Boutique {
  id          Int         @id @default(autoincrement())
  nom         String
  description String?

  vendeurId   Int         @unique
  vendeur     Utilisateur @relation(fields: [vendeurId], references: [id], onDelete: Cascade)

  produits    Produit[]

  createdAt   DateTime    @default(now())
}

model Produit {
  id          Int      @id @default(autoincrement())
  titre       String
  description String
  prix        Float
  image       String
  categorie   String
  stock       Int      @default(0)

  boutiqueId  Int
  boutique    Boutique @relation(fields: [boutiqueId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  items       CommandeItem[]
}

model Commande {
  id            Int           @id @default(autoincrement())
  utilisateurId Int
  utilisateur   Utilisateur   @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)

  total         Float
  status        CommandeStatus @default(EN_ATTENTE)

  items         CommandeItem[]

  createdAt     DateTime      @default(now())
}

model CommandeItem {
  id          Int      @id @default(autoincrement())
  commandeId  Int
  produitId   Int

  quantite    Int
  prixUnitaire Float

  commande    Commande @relation(fields: [commandeId], references: [id], onDelete: Cascade)
  produit     Produit  @relation(fields: [produitId], references: [id], onDelete: Restrict)
}
